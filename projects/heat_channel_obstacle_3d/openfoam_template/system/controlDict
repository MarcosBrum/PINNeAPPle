FoamFile
{
    version 2.0;
    format ascii;
    class dictionary;
    object controlDict;
}

application     laplacianFoam;

startFrom       startTime;
startTime       0;

stopAt          endTime;
endTime         1;

deltaT          1;

writeControl    timeStep;
writeInterval   1;

purgeWrite      0;

writeFormat     ascii;
writePrecision  10;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;